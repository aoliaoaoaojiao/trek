# Trek 环境变量配置示例
# 复制为 .env 或 .env.local 使用，不要提交包含真实密钥的文件。
#
# 加载顺序（优先级从低到高）：
#   .env                  — 全局默认值
#   .env.development.local — 开发环境本地覆盖（gitignore）
#   .env.local            — 本地覆盖（gitignore）
#
# 外部注入的环境变量（CI/CD、容器）始终优先。

# === 恢复记忆 ===
# 恢复经验持久化文件路径（SQLite）
# RECOVERY_MEMORY_FILE=recovery_memory.sqlite

# === OCR（PaddleOCR）===
# PADDLEOCR_API_URL=http://localhost:8866/predict/ocr_system
# PADDLEOCR_API_KEY=

# === LLM HTTP 网关 ===
# LLM_API_URL=https://your-llm-gateway/v1/chat/completions
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o

# === OpenAI 兼容接口 ===
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_API_URL=https://api.openai.com/v1/responses

# === Anthropic 兼容接口 ===
# ANTHROPIC_API_KEY=sk-xxx
# ANTHROPIC_MODEL=mimo-v2.5
# ANTHROPIC_API_URL=https://api.xiaomimimo.com/anthropic

# === ADB ===
# ADB_PATH=/usr/local/bin/adb
# ANDROID_HOME=/Users/you/Library/Android/sdk
# ANDROID_SDK_ROOT=/Users/you/Library/Android/sdk

# === FFmpeg（用于 scrcpy H.264 帧解码）===
# 不设置时自动在 PATH 中查找 ffmpeg
# FFMPEG_PATH=/path/to/ffmpeg
# TREK_FFMPEG_PATH=/path/to/ffmpeg

# === 集成测试 ===
# TREK_TEST_PACKAGE=com.example.app
