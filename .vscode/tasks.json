{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "go",
            "args": [
                "build",
                "-gcflags",
                "all=-N -l",
                "-o",
                "cmd/monkey/__debug_bin.exe",
                "./cmd/monkey"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "GO111MODULE": "on"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$go"]
        }
    ]
}
